{
  "$schema": "https://mintlify.com/docs.json",
  "name": "DOSS User App",
  "theme": "almond",
  "colors": {
    "primary": "#64dcfc",
    "light": "#448494",
    "dark": "#24252d"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/smonderoy/doss-userapp"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/smonderoy/doss-userapp"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "getting-started"]
          },
          {
            "group": "Authentication",
            "pages": [
              "authentication/overview",
              "authentication/registration",
              "authentication/login",
              "authentication/pin-management"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/dashboard",
              "features/scan-and-pay",
              "features/transaction-history",
              "features/notifications",
              "features/identity-verification",
              "features/groups"
            ]
          },
          {
            "group": "Profile & Settings",
            "pages": [
              "profile/overview",
              "profile/preferences",
              "profile/account-security",
              "profile/customer-support"
            ]
          },
          {
            "group": "Technical Reference",
            "pages": [
              "technical/architecture",
              "technical/navigation",
              "technical/state-management",
              "technical/api-integration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/profile",
              "api/payments",
              "api/transactions",
              "api/notifications",
              "api/identity",
              "api/groups"
            ]
          }
        ]
      }
    ]
  }
}
